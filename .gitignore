# =============================================================================
# .gitignore - Projet ETL ObRail Europe
# =============================================================================

# -----------------------------------------------------------------------------
# PYTHON
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
.venv/
venv/
ENV/
env/
.Env/

# PyInstaller
*.manifest
*.spec

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb_checkpoints

# -----------------------------------------------------------------------------
# DONNÉES PROJET (régénérables ou temporaires)
# -----------------------------------------------------------------------------
# Données brutes - peuvent être re-téléchargées
etl/data/raw/

# Données nettoyées - peuvent être re-générées
etl/data/clean/

# Anciennes données traitées
etl/data/processed/

# Logs d'exécution
etl/logs/

# Fichiers temporaires
*.tmp
*.temp
temp/
tmp/

# -----------------------------------------------------------------------------
# BASE DE DONNÉES
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
.postgres*
pgdata/

# Fichiers de configuration sensibles (si présents)
*.env
*.credentials
config/local.py

# -----------------------------------------------------------------------------
# CONFIGURATION & CACHE
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.coveragerc
cover/

# Type checking cache
pyrightconfig.json
mypy_cache/
.pdm-python/

# -----------------------------------------------------------------------------
# IDE & ÉDITEURS
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
ehthumbs.db

# -----------------------------------------------------------------------------
# DOCUMENTATION & PRESSE-PAPIER (non essentiels au code)
# -----------------------------------------------------------------------------
documents/
.amp/
gestion_projet/
note/
PLAN/
team/
reports/
# Ignorer tous les fichiers .md SAUF README.md
*.md
!README.md

# Fichiers temporaires
*.bak
*.backup
*~
\#*\#
.#*
