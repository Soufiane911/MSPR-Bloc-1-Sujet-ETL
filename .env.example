# Configuration de la base de données PostgreSQL
POSTGRES_USER=obrail
POSTGRES_PASSWORD=obrail_dbpw
POSTGRES_DB=obrail_db

# DATABASE_URL pour Docker (utilisé par les conteneurs api, dashboard, etl)
DATABASE_URL=postgresql://obrail:obrail_dbpw@database:5432/obrail_db

# Pour une exécution locale (hors Docker), utilisez :
# DATABASE_URL=postgresql://obrail:obrail_dbpw@localhost:5433/obrail_db

# Configuration de l'API
API_PORT=8000
API_HOST=0.0.0.0

# Configuration du Dashboard
DASHBOARD_PORT=8501

# Mode (development, production)
MODE=development
