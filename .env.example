# Configuration de la base de données PostgreSQL
# Hors Docker: localhost:5433 (port mappé)
# Dans Docker: database:5432 (nom du service)
POSTGRES_USER=obrail
POSTGRES_PASSWORD=obrail_dbpw
POSTGRES_DB=obrail_db
DATABASE_URL=postgresql://obrail:changeme@localhost:5433/obrail_db

# Configuration de l'API
API_PORT=8000
API_HOST=0.0.0.0

# Configuration du Dashboard
DASHBOARD_PORT=8501

# Mode (development, production)
MODE=development
